APP_NAME=ACEC
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ac-ec.com.sa

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=acec_dashboard
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

# For production, use redis/database cache:
# CACHE_STORE=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@ac-ec.com.sa"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# --- PRODUCTION OPTIMIZATION ---
# Set these env vars on the production server and run:
#   php artisan config:cache
#   php artisan route:cache
#   php artisan view:cache

# OPcache (set in php.ini, not .env):
#   opcache.enable=1
#   opcache.memory_consumption=256
#   opcache.max_accelerated_files=20000
#   opcache.revalidate_freq=60
